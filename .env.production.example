NODE_ENV=production
PORT=3001

DATABASE_URL=postgresql://pantrytrack:ganti-dengan-password-yang-kuat@host.docker.internal:5432/pantrytrack
DATABASE_SSL=false
DATABASE_SSL_REJECT_UNAUTHORIZED=true

SESSION_SECRET=ganti-dengan-random-string-minimal-32-karakter
APP_ORIGIN=https://rumahqu.example.com
COOKIE_SECURE=true
SESSION_TTL_HOURS=336
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=10
EMAIL_VERIFICATION_TTL_HOURS=24
PASSWORD_RESET_TTL_HOURS=2
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=no-reply@example.com
SMTP_PASS=ganti-dengan-password-smtp
SMTP_FROM=RumahQu <no-reply@example.com>
